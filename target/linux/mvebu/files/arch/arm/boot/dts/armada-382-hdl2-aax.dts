/dts-v1/;

#include "armada-385.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/thermal/thermal.h>

/ {
	model = "I-O DATA HDL2-AAX (0/2/4/6/8/12/16)";
	compatible = "iodata,hdl2-aax", "marvell,armada382", "marvell,armada380";

/*	aliases {
		led-boot = &led_ready;
		led-failsafe = &led_ready;
		led-running = &led_ready;
		led-upgrade = &led_ready;
		label-mac-device = &eth0;
	};*/

	chosen {
		bootargs = "console=ttyS0,115200n8";
		stdout-path = "serial0:115200n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x20000000>; /* 512MB */
	};

	soc {
		ranges = <MBUS_ID(0xf0, 0x01) 0 0xf1000000 0x100000
		          MBUS_ID(0x01, 0x1d) 0 0xfff00000 0x100000
		          MBUS_ID(0x09, 0x19) 0 0xf1100000 0x10000
		          MBUS_ID(0x09, 0x15) 0 0xf1110000 0x10000
		          MBUS_ID(0x0c, 0x04) 0 0xf1200000 0x100000
		          MBUS_ID(0x0b, 0x04) 0 0xf1300000 0x100000>;
	};

	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&gpio_keys_pins>;

		power {
			label = "power";
			linux,input-type = <EV_SW>;
			linux,code = <KEY_POWER>;
			gpios = <&gpio0 26 GPIO_ACTIVE_LOW>;
		};

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio0 27 GPIO_ACTIVE_LOW>;
		};
	};

/*	gpio-leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&gpio_leds_pins>;

		led_ready: ready {
			label = "blue:ready";
			gpios = <&gpio0 18 GPIO_ACTIVE_LOW>;
		};

		hdd {
			label = "blue:hdd";
			gpios = <&gpio0 20 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "disk-activity";
		};

		usb {
			label = "blue:usb";
			gpios = <&gpio1 19 GPIO_ACTIVE_HIGH>;
			trigger-sources = <&usb3_0_port1 &usb3_0_port2>;
			linux,default-trigger = "usbport";
		};
	};*/

	system_fan: gpio-fan {
		compatible = "gpio-fan";
		pinctrl-names = "default";
		pinctrl-0 = <&gpio_fan_pins>;
		gpios = <&gpio1 14 GPIO_ACTIVE_HIGH>,
		        <&gpio1 13 GPIO_ACTIVE_HIGH>;
		/* We don't know the exact rpm, just use dummy values here. */
		gpio-fan,speed-map = <0 0>, <1 1>, <2 2>;
		#cooling-cells = <2>;
	};

	gpio-poweroff {
		compatible = "gpio-poweroff";
		pinctrl-names = "default";
		pinctrl-0 = <&system_power_pins>;
		gpios = <&gpio0 28 GPIO_ACTIVE_HIGH>;
		active-delay-ms = <1000>;
	};

	regulators {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&sata_power_pins>;

		reg_sata_power: regulator@1 {
			compatible = "regulator-fixed";
			reg = <1>;
			regulator-name = "sata-power";
			regulator-min-microvolt = <12000000>;
			regulator-max-microvolt = <12000000>;
			enable-gpios = <&gpio0 30 GPIO_ACTIVE_HIGH>;
			regulator-always-on;
			enable-active-high;
		};
	};

	thermal-zones {
		sata0-thermal {
			polling-delay = <2000>;
			polling-delay-passive = <2000>;

			thermal-sensors = <&sata_port0>;

			trips {
				sata0_alart1: trip1 {
					temperature = <36000>;
					hysteresis = <2000>;
					type = "active";
				};

				sata0_alart2: trip2 {
					temperature = <50000>;
					hysteresis = <2000>;
					type = "passive";
				};

				trip3 {
					temperature = <60000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};

			cooling-maps {
				map1 {
					trip = <&sata0_alart1>;
					cooling-device = <&system_fan THERMAL_NO_LIMIT 1>;
				};

				map2 {
					trip = <&sata0_alart2>;
					cooling-device = <&system_fan 2 THERMAL_NO_LIMIT>;
				};
			};
		};

		sata1-thermal {
			polling-delay = <2000>;
			polling-delay-passive = <2000>;

			thermal-sensors = <&sata_port1>;

			trips {
				sata1_alart1: trip1 {
					temperature = <36000>;
					hysteresis = <2000>;
					type = "active";
				};

				sata1_alart2: trip2 {
					temperature = <50000>;
					hysteresis = <2000>;
					type = "passive";
				};

				trip3 {
					temperature = <60000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};

			cooling-maps {
				map1 {
					trip = <&sata1_alart1>;
					cooling-device = <&system_fan THERMAL_NO_LIMIT 1>;
				};

				map2 {
					trip = <&sata1_alart2>;
					cooling-device = <&system_fan 2 THERMAL_NO_LIMIT>;
				};
			};
		};

		system-thermal {
			polling-delay = <2000>;
			polling-delay-passive = <2000>;

			thermal-sensors = <&system_temp>;

			trips {
				system_alart1: trip1 {
					temperature = <40000>;
					hysteresis = <2000>;
					type = "active";
				};

				system_alart2: trip2 {
					temperature = <52000>;
					hysteresis = <2000>;
					type = "passive";
				};

				trip3 {
					temperature = <60000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};

			cooling-maps {
				map1 {
					trip = <&system_alart1>;
					cooling-device = <&system_fan THERMAL_NO_LIMIT 1>;
				};

				map2 {
					trip = <&system_alart2>;
					cooling-device = <&system_fan 2 THERMAL_NO_LIMIT>;
				};
			};
		};
	};
};

&ahci0 {
	status = "okay";
	nr-ports = <2>;
	#address-cells = <1>;
	#size-cells = <0>;

	sata_port0: sata-port@0 {
		reg = <0>;
		target-supply = <&reg_sata_power>;
		#thermal-sensor-cells = <0>;
	};

	sata_port1: sata-port@1 {
		reg = <1>;
		target-supply = <&reg_sata_power>;
		#thermal-sensor-cells = <0>;
	};
};

&bm {
	status = "okay";
};

&bm_bppi {
	status = "okay";
};

&eth0 {
	pinctrl-names = "default";
	pinctrl-0 = <&ge0_rgmii_pins>;
	status = "okay";
	phy-handle = <&ethphy0>;
	phy-connection-type = "2500base-x";
	buffer-manager = <&bm>;
	bm,pool-long = <0>;
	bm,pool-short = <1>;
};

&gpio0 {
	board-model {
		pinctrl-names = "default";
		pinctrl-0 = <&board_detection_pins>;

		gpio-hog;
		gpios = <18 GPIO_ACTIVE_HIGH>, <19 GPIO_ACTIVE_HIGH>,
			<20 GPIO_ACTIVE_HIGH>, <21 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "board-model";
	};
};

&gpio1 {
	board-model {
		gpio-hog;
		gpios = <9 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "board-model";
	};

	ac-detection {
		gpio-hog;
		gpios = <11 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "AC-detection";
	};
};

&i2c0 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c0_pins>;
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	system_temp: sensor@49 {
		compatible = "ti,tmp75";
		reg = <0x49>;
		#thermal-sensor-cells = <0>;
	};

	eeprom@50 {
		compatible = "rohm,br24g02", "atmel,24c02";
		reg = <0x50>;
		#address-cells = <1>;
		#size-cells = <1>;

		uptime@4 {
			reg = <0x4 0x4>;
		};

		fan-using-time@8 {
			reg = <0x8 0x4>;
		};

		power-time@c {
			reg = <0xc 0x4>;
		};

		power-cycle-count@10 {
			reg = <0x10 0x4>;
		};

		fan-fail-count@14 {
			reg = <0x14 0x4>;
		};

		temp-fail-count@18 {
			reg = <0x18 0x4>;
		};

		no-warranty@1c {
			reg = <0x1c 0x1>;
		};

		boot-on-ac@1d {
			reg = <0x1d 0x1>;
		};

		wol-enable@1e {
			reg = <0x1e 0x1>;
		};

		boot-beep@1f {
			reg = <0x1f 0x1>;
		};

		led-brightness@20 {
			reg = <0x20 0x1>;
		};
	};
};

&mdio {
	pinctrl-names = "default";
	pinctrl-0 = <&mdio_pins>;

	ethphy0: ethernet-phy@0 {
		reg = <0>;
		max-speed = <2500>;
	};
};

&pinctrl {
	gpio_keys_pins: gpio-keys-pins {
		marvell,pins = "mpp26", "mpp27";
		marvell,function = "gpio";
	};

	gpio_leds_pins: gpio-leds-pins {
		marvell,pins = "mpp29", "mpp31", "mpp32", "mpp33", "mpp34",
			       "mpp35", "mpp47";
		marvell,function = "gpio";
	};

	gpio_fan_pins: gpio-fan-pins {
		/*
		 * 42: rotation detection
		 * 45: Speed High
		 * 46: Speed Low
		 */
		marvell,pins = "mpp42", "mpp45", "mpp46";
		marvell,function = "gpio";
	};

	sata_power_pins: sata-power-pins {
		marvell,pins = "mpp30";
		marvell,function = "gpio";
	};

	system_power_pins: system-power-pins {
		marvell,pins = "mpp28";
		marvell,function = "gpio";
	};

	ac_detection_pins: ac-detection-pins {
		marvell,pins = "mpp43";
		marvell,function = "gpio";
	};

	board_detection_pins: board-detection-pins {
		/*
		 * Bit:  4   3   2   1   0
		 * Pin: 41  21  20  19  18
		 *
		 * Models:
		 *   0: HDL-AA
		 *   1: HDL2-AA
		 *   2: ?
		 *   3: HDL2-AAX
		 */
		marvell,pins = "mpp18", "mpp19", "mpp20", "mpp21", "mpp41";
		marvell,function = "gpio";
	};
};

&spi0 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi0_pins>;
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <40000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				reg = <0x00000000 0x00100000>;
				label = "u-boot";
				read-only;
			};

			partition@f0000 {
				reg = <0x000f0000 0x00010000>;
				label = "u-boot-env";
				read-only;
			};

			partition@100000 {
				reg = <0x00100000 0x00f00000>;
				label = "system";
				read-only;
			};
		};
	};
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pins>;
	status = "okay";
};

&usb3_0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	hub@1 {
		compatible = "usb5e3,608";
		reg = <1>;

		port@1 {
			reg = <1>;
		};

		port@2 {
			reg = <2>;
		};
	};
};

&usb3_1 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	port@1 {
		reg = <1>;
	};
};
