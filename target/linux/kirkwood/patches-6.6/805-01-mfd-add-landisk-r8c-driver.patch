--- a/drivers/mfd/Kconfig
+++ b/drivers/mfd/Kconfig
@@ -2333,5 +2333,13 @@ config MFD_RSMU_SPI
 	  Additional drivers must be enabled in order to use the functionality
 	  of the device.
 
+config MFD_LANDISK_R8C
+	bool "Renesas R8C MCU on I-O DATA LAN DISK series"
+	depends on SERIAL_DEV_CTRL_TTYPORT
+	help
+	  This option enables common support for the Renesas R8C MCU on
+	  I-O DATA LAN DISK series NAS. It has several functions, such as
+	  LEDs, keys, temperature sensor, fan controller, and others.
+
 endmenu
 endif
