/dts-v1/;

#include "kirkwood.dtsi"
#include "kirkwood-6282.dtsi"

#include <dt-bindings/leds/common.h>

/ {
	model = "Plat'Home OpenBlocks A7";
	compatible = "plathome,obsa7p", "marvell,kirkwood-88f6283", "marvell,kirkwood";

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x40000000>;
	};

	aliases {
		serial0 = &uart0;
		led-boot = &led_status_green;
		led-failsafe = &led_status_yellow;
		led-running = &led_status_green;
		led-upgrade = &led_status_green;
	};

	chosen {
		bootargs = "console=ttyS0,115200n8 earlycon";
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-0 = <&pmx_led_pins>;
		pinctrl-names = "default";

		led-0 {
			label = "red:status";
			gpios = <&gpio1 9 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_STATUS;
		};

		led_status_green: led-1 {
			label = "green:status";
			gpios = <&gpio1 10 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
		};

		led_status_yellow: led-2 {
			label = "yellow:status";
			gpios = <&gpio1 11 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_YELLOW>;
			function = LED_FUNCTION_STATUS;
		};
	};

	keys {
		compatible = "gpio-keys";
		pinctrl-0 = <&pmx_btn_pins>;
		pinctrl-names = "default";

		init {
			label = "init";
			gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
			linux,code = <KEY_RESTART>;
		};
	};

	gpio-export {
		compatible = "gpio-export";
		pinctrl-0 = <&pmx_gpio_header_pins>;
		pinctrl-names = "default";

		/*
		 * GPIO Header on PCB (J202)
		 *
		 * - Assignment
		 *
		 *    1: MPP17(GPIO_17, don't pull down)
		 *    2: NC
		 *    3: MPP29 (GPIO_29)
		 *    4: MPP28 (GPIO_28)
		 *    5: MPP35 (GPIO_35)
		 *    6: MPP34 (GPIO_34)
		 *    7: MPP40 (GPIO_40)
		 *    8: NC
		 *    9: RESET input
		 *   10: GND
		 *
		 * - Arrangement
		 *
		 *   | 9| 7| 5| 3| 1|  DC input -->
		 *   |10| 8| 6| 4| 2|
		 */

		gpio17 {
			gpio-export,name = "GPIO_17";
			gpio-export,output = <1>;
			gpios = <&gpio0 17 GPIO_ACTIVE_HIGH>;
		};

		gpio28 {
			gpio-export,name = "GPIO_28";
			gpio-export,output = <1>;
			gpios = <&gpio0 28 GPIO_ACTIVE_HIGH>;
		};

		gpio29 {
			gpio-export,name = "GPIO_29";
			gpio-export,output = <1>;
			gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
		};

		gpio34 {
			gpio-export,name = "GPIO_34";
			gpio-export,output = <1>;
			gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>;
		};

		gpio35 {
			gpio-export,name = "GPIO_35";
			gpio-export,output = <1>;
			gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
		};

		gpio40 {
			gpio-export,name = "GPIO_40";
			gpio-export,output = <1>;
			gpios = <&gpio1 8 GPIO_ACTIVE_HIGH>;
		};
	};
};

&nand {
	status = "okay";

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		partition@0 {
			label = "u-boot";
			reg = <0x00 0x1c0000>;
		};

		partition@1c0000 {
			label = "u-boot-env";
			reg = <0x1c0000 0x2c0000>;
		};

		partition@480000 {
			label = "test";
			reg = <0x480000 0x160000>;
		};

		partition@5e0000 {
			label = "conf";
			reg = <0x5e0000 0x540000>;
		};

		partition@b20000 {
			label = "linux";
			reg = <0xb20000 0x3d40000>;
		};

		partition@4860000 {
			label = "user";
			reg = <0x4860000 0xb7a0000>;
		};
	};
};

&pinctrl {
	pmx_gpio_header_pins: gpio-header-pins {
		marvell,pins = "mpp17", "mpp28", "mpp29", "mpp34",
				   "mpp35", "mpp40";
		marvell,function = "gpio";
	};

	pmx_btn_pins: btn-pins {
		marvell,pins = "mpp38";
		marvell,function = "gpio";
	};

	pmx_usb_oc_pins: usb-oc-pins {
		marvell,pins = "mpp39";
		marvell,function = "gpio";
	};

	pmx_led_pins: led-pins {
		marvell,pins = "mpp41", "mpp42", "mpp43";
		marvell,function = "gpio";
	};

	pmx_dipsw_pins: dipsw-pins {
		marvell,pins = "mpp44", "mpp45", "mpp46", "mpp47";
		marvell,function = "gpio";
	};
};

&gpio1 {
	pinctrl-0 = <&pmx_dipsw_pins>;
	pinctrl-names = "default";

	dipsw-0 {
		gpio-hog;
		gpios = <12 GPIO_ACTIVE_HIGH>;
		input;
	};

	dipsw-1 {
		gpio-hog;
		gpios = <13 GPIO_ACTIVE_HIGH>;
		input;
	};

	dipsw-2 {
		gpio-hog;
		gpios = <14 GPIO_ACTIVE_HIGH>;
		input;
	};

	dipsw-3 {
		gpio-hog;
		gpios = <15 GPIO_ACTIVE_HIGH>;
		input;
	};
};

/* "CONSOLE" port */
&uart0 {
	status = "okay";
};

/* "RS-232C" port */
&uart1 {
	status = "okay";
};

&usb {
	pinctrl-0 = <&pmx_usb_oc_pins>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;

	hub@1 {
		compatible = "usb424,2514";
		reg = <1>;
	};
};

&eth0 {
	status = "okay";
};

&eth0port {
	phy-handle = <&ethphy0>;
	phy-connection-type = "rgmii";
};

&eth1 {
	status = "okay";
};

&eth1port {
	phy-handle = <&ethphy1>;
	phy-connection-type = "rgmii";
};

&mdio {
	status = "okay";

	ethphy0: ethernet-phy@0 {
		reg = <0>;
	};

	ethphy1: ethernet-phy@1 {
		reg = <1>;
	};
};

&i2c1 {
	status = "okay";
};

&sata {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;
	nr-ports = <1>;

	sata-port@0 {
		reg = <0>;
		#thermal-sensor-cells = <0>;
	};
};
