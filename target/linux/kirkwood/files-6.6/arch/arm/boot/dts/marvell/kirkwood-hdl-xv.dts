/dts-v1/;

#include <dt-bindings/leds/common.h>
#include "kirkwood.dtsi"
#include "kirkwood-6281.dtsi"

/ {
	model = "I-O DATA HDL-XV";
	compatible = "iodata,hdl-xv", "marvell,kirkwood-88f6281", "marvell,kirkwood";

	aliases {
		serial0 = &uart0;
		serial1 = &uart1;
	};

	chosen {
		bootargs-append = " earlycon root=PARTUUID=5452574f-2211-4433-5566-778899aabb02 rootwait=20";
		stdout-path = "serial0:115200n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x10000000>;
	};
};

&i2c0 {
	status = "okay";

	rtc@32 {
		compatible = "ricoh,rs5c372a";
		reg = <0x32>;
		/* enable alarm for powering on by R8C MCU */
		wakeup-source;
	};
};

&pciec {
	status = "okay";
};

&pcie0 {
	status = "okay";

	/* Intel 82574L */
	ethernet@0,0 {
		compatible = "pci8086,10d3";
		reg = <0x0000 0 0 0 0>;
	};
};

&rtc {
	status = "disabled";
};

&sata {
	status = "okay";
	nr-ports = <2>;
	#address-cells = <1>;
	#size-cells = <0>;

	/* external eSATA port on rear panel */
	sata-port@0 {
		reg = <0>;
	};

	/*
	 * internal 4x SATA ports provided by
	 * a port multiplier (Marvell 88SM4140)
	 */
	sata-port@1 {
		reg = <1>;
	};
};

&spi0 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		spi-max-frequency = <40000000>;
		reg = <0>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x00000 0x70000>;
				read-only;
			};

			partition@70000 {
				label = "u-boot-env";
				reg = <0x70000 0x10000>;
				read-only;
			};

			partition@80000 {
				label = "jffs2";
				reg = <0x80000 0x780000>;
				read-only;
			};
		};
	};
};

&uart0 {
	status = "okay";
};

&uart1 {
	status = "okay";

	mcu {
		compatible = "iodata,landisk-r8c";
		iodata,landisk-r8c-model = "HDL-XV";

		buttons {
			compatible = "iodata,landisk-r8c-keys-event";

			/* 'c' */
			key-function {
				label = "func.";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x63>;
				linux,code = <KEY_COPY>;
			};

			/* 'p' */
			key-power {
				label = "power";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x70>;
				linux,code = <KEY_POWER>;
			};

			/* 'r' */
			key-reset {
				label = "reset";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x72>;
				linux,code = <KEY_RESTART>;
			};
		};

		hdds {
			compatible = "iodata,landisk-r8c-keys-polled";

			/* 'w' */
			switch-hdd1 {
				label = "hdd1";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x77>;
				linux,code = <BTN_1>;
			};

			/* 'x' */
			switch-hdd2 {
				label = "hdd2";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x78>;
				linux,code = <BTN_2>;
			};

			/* 'y' */
			switch-hdd3 {
				label = "hdd3";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x79>;
				linux,code = <BTN_3>;
			};

			/* 'z' */
			switch-hdd4 {
				label = "hdd4";
				iodata,landisk-r8c-keycode = /bits/ 8 <0x7a>;
				linux,code = <BTN_4>;
			};
		};

		leds {
			compatible = "iodata,landisk-r8c-leds";
			#address-cells = <1>;
			#size-cells = <0>;

			led@0 {
				reg = <0>;
				color = <LED_COLOR_ID_MULTI>;
				function = LED_FUNCTION_DISK_ACTIVITY;
				function-enumerator = <1>;
			};

			led@1 {
				reg = <1>;
				color = <LED_COLOR_ID_MULTI>;
				function = LED_FUNCTION_DISK_ACTIVITY;
				function-enumerator = <2>;
			};

			led@2 {
				reg = <2>;
				color = <LED_COLOR_ID_MULTI>;
				function = LED_FUNCTION_DISK_ACTIVITY;
				function-enumerator = <3>;
			};

			led@3 {
				reg = <3>;
				color = <LED_COLOR_ID_MULTI>;
				function = LED_FUNCTION_DISK_ACTIVITY;
				function-enumerator = <4>;
			};
		};

		reset {
			compatible = "iodata,landisk-r8c-reset";
		};
	};
};

&usb0 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	hub@1 {
		compatible = "usb409,005a";
		reg = <1>;
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
		};

		port@2 {
			reg = <2>;
		};
	};
};
