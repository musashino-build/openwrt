pi_indicate_preinit_landisk() {
	. /lib/functions.sh
	case $(board_name) in
	iodata,hdl-a-sata|\
	iodata,hdl-a-usb|\
	iodata,hdl2-a-sata|\
	iodata,hdl2-a-usb)
		# set green/blink
		echo "blink" > "/sys/bus/serial/devices/serial0-0/f1012100.serial:mcu:leds/status_mode"
		;;
	esac
}

boot_hook_add preinit_main pi_indicate_preinit_landisk
