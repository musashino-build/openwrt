indicate_failsafe_led_landisk() {
	. /lib/functions.sh
	case $(board_name) in
	iodata,hdl2-a-sata|\
	iodata,hdl2-a-usb)
		local ledpath="/sys/bus/serial/devices/serial0-0/f1012100.serial:mcu:leds/status_mode"
		# set red/blink
		echo "serious_err" > $ledpath
		;;
	esac
}

boot_hook_add failsafe indicate_failsafe_led_landisk
